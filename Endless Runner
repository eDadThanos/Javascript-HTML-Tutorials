
<!DOCTYPE html>
<html>
<head>
    <title>ENDLESS RUNNER</title>
</head>
<body>
    <canvas id="canvas" width="640" height="480"></canvas>
    
    <script>
        var canvas = document.getElementById("canvas");
        var ctx = canvas.getContext("2d");

        var world = {
            height: 480,
            width: 640,
            gravity: 10,
            speed: 10,
            distanceTravelled: 0,
            highestFloor: 240,
            gravity: 9.81,
            autoScroll: true,

            floorTiles: [
                new Floor(0, 140)
            ],

            tick: function() {
                if(!this.autoScroll) {
                    return;
                }
                this.cleanUpOldTiles();
                this.addFutureTiles();
                this.moveFloor();
            },

            stop: function() {
                this.autoScroll = false
            },

            draw: function() {
                ctx.fillStyle = "black";
                ctx.fillRect(0, 0, this.width, this.height);
                
                for(var index in this.floorTiles) {
                    var tile = this.floorTiles[index];
                    var y = this.height - tile.height; 
                    ctx.fillStyle = "blue";
                    ctx.fillRect(tile.x, y, tile.width, tile.height);
                }
            },

            moveFloor: function() {
                for (index in this.floorTiles) {
                    var tile = this.floorTiles[index];
                    tile.x -= this.speed;
                    this.distanceTravelled += this.speed
                }
            },

            addFutureTiles: function() {
                if ( this.floorTiles.length >= 3) {
                    return;
                }
                var previousTile = this.floorTiles[this.floorTiles.length -1];
                var randomHeight = Math.floor(Math.random() * this.highestFloor) + 20;
                var leftValue = (previousTile.x+previousTile.width);
                var next = new Floor(leftValue, randomHeight);
                this.floorTiles.push(next);
            },

            cleanUpOldTiles: function() {
                for (index in this.floorTiles){
                    if (this.floorTiles[index].x <= -this.floorTiles[index].width) {
                        this.floorTiles.splice(index, 1)
                    }
                }
            },

            getDistanceToFloor: function(playerX) {
                for (index in this.floorTiles) {
                    var tile = this.floorTiles[index];
                    if (tile.x <= playerX && playerX <= tile.x+tile.width) {
                        return tile.height;
                    }
                }
                return -1;
            }
        };

        var player = {
            x: 100,
            y: world.highestFloor,
            height: 20,
            width: 20,
            currentDistanceAboveGround: 0,

            tick: function(){
                this.processGravity();
                this.applyGravity();
            },

            draw: function() {
                ctx.fillStyle = "green";
                ctx.fillRect(player.x, player.y - player.height, player.width, player.height);
            },
            
            getDistanceFor: function(x) {
                var platformBelow = world.getDistanceToFloor(x);
                return world.height - this.y - platformBelow;
            },

            applyGravity: function() {
                if(this.getDistanceFor(this.x) < 0 || this.getDistanceFor(this.x + this.width) < 0){
                    world.stop();
                }
            },

            processGravity: function() {
                this.y += world.gravity;
                var floorHeight = world.getDistanceToFloor(this.x);
                var topYofPlatform = world.height - floorHeight;
                if (this.y > topYofPlatform) {
                    this.y = topYofPlatform;
                }

            }


        }


        function Floor(x, height) {
            this.x = x;
            this.width = 700;
            this.height = height;
        }

        function tick() {
            world.tick();
            player.tick();
            world.draw();
            player.draw();
            window.setTimeout("tick()", 1000/60)
        }

        tick();
    </script>
</body>
</html>
